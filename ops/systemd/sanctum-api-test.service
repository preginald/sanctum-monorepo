[Unit]
Description=Sanctum Core API — Test (FastAPI)
After=network.target

[Service]
User=preginald
Group=preginald
WorkingDirectory=/home/preginald/DigitalSanctum-test/sanctum-core
Environment="PATH=/home/preginald/DigitalSanctum-test/sanctum-core/venv/bin"
EnvironmentFile=/home/preginald/DigitalSanctum-test/sanctum-core/.env
ExecStart=/home/preginald/DigitalSanctum-test/sanctum-core/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8001

[Install]
WantedBy=multi-user.target
