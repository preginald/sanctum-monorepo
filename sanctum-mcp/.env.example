# Default API token (fallback when X-Sanctum-Agent header is absent)
SANCTUM_API_TOKEN=sntm_your_token_here
SANCTUM_API_BASE=https://core.digitalsanctum.com.au/api
MCP_HOST=0.0.0.0
MCP_PORT=8100
# Token guard: max section count before routing to section-level fetching (default 8)
MCP_SECTION_THRESHOLD=8
MCP_AGENT_PERSONA=unknown
# httpx connection pool limits (default: 100 max connections, 50 keepalive)
# NOTE: shared by both Core and Notify upstream clients — do NOT add a second pair.
MCP_MAX_CONNECTIONS=100
MCP_MAX_KEEPALIVE=50

# Agent identity tokens (loaded by AgentIdentityMiddleware)
# Each maps to a per-agent Core API token; resolved via X-Sanctum-Agent header
SANCTUM_TOKEN_ARCHITECT=
SANCTUM_TOKEN_OPERATOR=
SANCTUM_TOKEN_SCRIBE=
SANCTUM_TOKEN_SENTINEL=
SANCTUM_TOKEN_SURGEON=
SANCTUM_TOKEN_ORACLE=
SANCTUM_TOKEN_CHAT=

# ─── Sanctum Notify upstream ──────────────────────────────────────────
# Separate upstream from Core — Notify has its own base URL and bearer
# token (SHA-256 hashed ApiKey rows, per-tenant). Tools in tools/notify.py
# use these env vars via client_notify.py. A single process-level token
# is used in v1; per-agent Notify identities are deferred to a follow-up
# that adapts SYS-057 for Notify.
NOTIFY_API_BASE=https://notify.digitalsanctum.com.au/api
NOTIFY_API_TOKEN=
