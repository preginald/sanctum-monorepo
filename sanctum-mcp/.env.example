SANCTUM_API_TOKEN=sntm_your_token_here
SANCTUM_API_BASE=https://core.digitalsanctum.com.au/api
MCP_HOST=0.0.0.0
MCP_PORT=8100
# Token guard: max section count before routing to section-level fetching (default 8)
MCP_SECTION_THRESHOLD=8
MCP_AGENT_PERSONA=unknown
# httpx connection pool limits (default: 100 max connections, 50 keepalive)
MCP_MAX_CONNECTIONS=100
MCP_MAX_KEEPALIVE=50
